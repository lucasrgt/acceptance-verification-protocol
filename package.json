{
  "name": "assay",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "examples/*"
  ],
  "description": "Assay — the reference JS/React implementation of AVP (Acceptance Verification Protocol). Deterministic behavior verification for AI-built web features: tap the vein and confirm it's remediated.",
