{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "assay": ["../../src/index.ts"],
      "assay/react": ["../../src/adapter-react/index.ts"],
      "assay/react/vitest": ["../../src/adapter-react/vitest.ts"]
    },
    "noEmit": true
  },
  "include": ["src", "assay", "vite.config.ts", "vitest.setup.ts"]
}
